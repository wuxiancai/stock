# 股票交易系统环境配置文件

# 应用基本配置
APP_NAME=股票交易系统
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# 服务端口配置
BACKEND_PORT=8080
FRONTEND_PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_db
DB_USER=stock_user
DB_PASSWORD=stock_password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 完整数据库URL（自动生成，通常不需要修改）
DATABASE_URL=postgresql://stock_user:stock_password@localhost:5432/stock_db

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# 数据源API配置
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_TIMEOUT=30

# JWT配置
ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# 缓存配置
CACHE_TTL=300
STOCK_DATA_CACHE_TTL=60
REALTIME_DATA_CACHE_TTL=5

# 数据更新配置
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=15:00
DATA_UPDATE_INTERVAL=60
AUTO_UPDATE_ENABLED=true

# 技术分析配置
NINE_TURN_LOOKBACK_DAYS=30
TECHNICAL_INDICATOR_PERIODS=5,10,20,30,60

# 邮件配置（可选）
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# 监控配置
ENABLE_MONITORING=true
ALERT_EMAIL=
HEALTH_CHECK_INTERVAL=60

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=true

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# API限流配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads