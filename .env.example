# 环境配置
ENVIRONMENT=development

# 数据库配置
DATABASE_URL=postgresql+asyncpg://stock_user:stock_password@localhost:5432/stock_trading_db
DATABASE_URL_SYNC=postgresql://stock_user:stock_password@localhost:5432/stock_trading_db

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API密钥配置
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_TIMEOUT=30

# JWT配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 应用配置
APP_NAME=Stock Trading System
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8080

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 数据更新配置
UPDATE_INTERVAL_MINUTES=5
BATCH_SIZE=100
MAX_RETRIES=3

# 缓存配置
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# 监控配置
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL=60

# 跨域配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# WebSocket配置
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_MAX_CONNECTIONS=1000

# 文件上传配置
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=uploads

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# 第三方API配置
REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_PER_MINUTE=60