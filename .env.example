# 环境变量配置文件

# 应用配置
APP_NAME=股票交易系统
APP_VERSION=1.0.0
DEBUG=true
PORT=8080

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/stock_db
ASYNC_DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/stock_db

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# JWT配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据源API配置
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_TIMEOUT=30

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# 缓存配置
CACHE_TTL=300
STOCK_DATA_CACHE_TTL=60
REALTIME_DATA_CACHE_TTL=5

# 数据更新配置
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=15:00
DATA_UPDATE_INTERVAL=60
AUTO_UPDATE_ENABLED=true

# 技术分析配置
NINE_TURN_LOOKBACK_DAYS=30
TECHNICAL_INDICATOR_PERIODS=5,10,20,30,60

# 服务端口配置
BACKEND_PORT=8080
FRONTEND_PORT=3000

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=true

# 邮件配置（可选）
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_TLS=true

# 监控配置
ENABLE_MONITORING=true
ALERT_EMAIL=admin@example.com
HEALTH_CHECK_INTERVAL=60

# 限流配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads